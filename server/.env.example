# PostgreSQL connection string
# Make sure the database exists; schemas will be created by `prisma migrate dev`.
#
# Default points to the Dockerised Postgres in docker-compose.yml (port 5433
# so it doesn't collide with a local Postgres on 5432). If you use your own
# Postgres, replace user/password/host/port/db accordingly.
DATABASE_URL="postgresql://inventario:inventario_dev@localhost:5433/inventario?schema=public"

# JWT
JWT_SECRET="change-me-in-production-please-make-it-long-and-random"
JWT_EXPIRES_IN="1d"

# HTTP server
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Auth
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173
